# Security headers for moggers.in (Workers static assets).
#
# SCOPE: this file applies ONLY to static assets. Cloudflare does not apply it to
# responses generated by Worker code, so every /api/* response sets its own
# headers in worker/security.js. Change one, change the other.
#
# NO INLINE SCRIPT HASHES NEEDED. index.html carries exactly one <script>, and it
# is external (`<script type="module" src="/src/main.js">`). That is why this CSP
# has no {{INLINE_SCRIPT_HASHES}} placeholder and no build-time hashing step,
# unlike robosimtools — Astro inlines its script blocks, this site does not.
# If you ever add an inline <script> or a style="" attribute, this CSP will block
# it. Fix the markup rather than loosening the policy.
#
# Why each non-obvious directive is here:
#   'wasm-unsafe-eval'  — pdf.js and the Draco decoder instantiate WebAssembly.
#                         This permits WASM only; it does NOT permit eval().
#   worker-src blob:    — pdf.js runs its parser in a Worker created from a
#                         bundled URL; Vite may hand it a blob.
#   img-src data:       — the favicon is an inline SVG data: URI.
#   connect-src 'self'  — the ONLY network destination. This is what makes the
#                         "nothing is uploaded" claim mechanically enforced and
#                         not merely a promise: no third-party origin is
#                         reachable from the page, so a resume cannot leave.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Strict-Transport-Security: max-age=15552000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; worker-src 'self' blob:; media-src 'none'; object-src 'none'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests

# Hashed filenames are immutable — safe to cache hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The sample PDF and the statue GLB are content, not code: revalidate.
/sample/*
  Cache-Control: public, max-age=86400
/models/*
  Cache-Control: public, max-age=86400
