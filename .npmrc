# `npm install` fails without this, and the conflict it silences is spurious.
#
# `agents` declares an OPTIONAL peer on vite >=6 <9. This project pins vite 5 for
# the static build, so npm refuses the whole install — even though the peer only
# exists for `agents/vite`, a dev-server plugin nothing here imports.
#
# The alternative was bumping vite a major version or two on a live site as a
# side effect of adding a Durable Object, which is a far bigger change than the
# problem. Revisit if vite is upgraded for its own reasons.
legacy-peer-deps=true
